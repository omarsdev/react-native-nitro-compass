{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "nitrocompass"
  ],
  "ios": {
    "iosModuleName": "NitroCompass"
  },
  "android": {
    "androidNamespace": [
      "nitrocompass"
    ],
    "androidCxxLibName": "NitroCompass"
  },
  "autolinking": {
    "NitroCompass": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridNitroCompass"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridNitroCompass"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}